# --- Supabase (cote client Next.js, exposees au navigateur) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Option historique:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (cote serveur / API routes) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Service role (JAMAIS exposer au client) ---
# Necessaire pour : script de creation d'utilisateur admin, uploads serveur
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Storage (bucket public pour les medias : images + audio) ---
SUPABASE_STORAGE_BUCKET=media

# --- Compte admin initial (utilise par `npm run create-admin`) ---
ADMIN_EMAIL=thomas@site.com
ADMIN_PASSWORD=ChangeMoiEnUnMotDePasseFort!2026

# --- Mode presentation (demo locale SANS Supabase) ---
# Active une connexion admin via cookie HttpOnly + routes /api/demo-auth/*.
# Ne pas activer sur un site public en production.
DEMO_PRESENTATION=false
# Mot de passe attendu sur /login quand DEMO_PRESENTATION=true (defaut code : Presentation2026!)
DEMO_PRESENTATION_PASSWORD=Presentation2026!
