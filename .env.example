# ============================================================
#  Développement local — copier en `.env`
#  Production VPS : utiliser `.env.production.example` à la place.
# ============================================================

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sport_journal?schema=public"

JWT_SECRET="change-me-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Thomas Palmier"

# Admin /monsite — seul cet email peut se connecter
ADMIN_EMAIL="contact@thomaspalmier.fr"
ADMIN_PASSWORD="ChangeMoiEnUnMotDePasseFort!2026"

# Contact affiché sur /contact
CONTACT_EMAIL="contact@thomaspalmier.fr"
NEXT_PUBLIC_CONTACT_EMAIL="contact@thomaspalmier.fr"
NEXT_PUBLIC_ADMIN_EMAIL_HINT="contact@thomaspalmier.fr"

# SMTP (local : laisser vide ou renseigner pour tester la newsletter)
EMAIL_USER="contact@thomaspalmier.fr"
EMAIL_PASS="change-me"
SMTP_HOST="smtp.ionos.fr"
SMTP_PORT="587"
SMTP_SECURE="false"
MAIL_FROM="Thomas Palmier <contact@thomaspalmier.fr>"

# Cron interne (rappels agenda 24 h) — générer : openssl rand -base64 32
CRON_SECRET="change-me-cron-secret"
