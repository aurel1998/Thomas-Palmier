generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  video
  article
  audio
}

enum UserRole {
  admin
  editor
  journalist
}

enum CredibilityKind {
  media
  partner
  award
  institution
}

enum PublicationStatus {
  draft
  published
}

enum NewsletterCampaignKind {
  campaign
  content
  agenda
  reminder
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique
  emailVerified     DateTime?         @map("email_verified") @db.Timestamptz(6)
  name              String            @map("full_name")
  image             String?           @map("image_url")
  passwordHash      String            @map("password_hash")
  role              UserRole          @default(journalist)
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts          Account[]
  sessions          Session[]
  categoriesCreated    Category[]      @relation("CategoryCreatedBy")
  subcategoriesCreated Subcategory[]   @relation("SubcategoryCreatedBy")
  contentsCreated      Content[]       @relation("ContentCreatedBy")
  eventsCreated        Event[]         @relation("EventCreatedBy")
  profile           JournalistProfile?

  @@index([createdAt(sort: Desc)], map: "users_created_at_idx")
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_user_id_idx")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String    @default("")
  position    Int       @default(100)
  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  contents      Content[]
  subcategories Subcategory[]
  createdBy     User?         @relation("CategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById], map: "categories_created_by_id_idx")
  @@map("categories")
}

model Subcategory {
  id          String    @id @default(uuid()) @db.Uuid
  categoryId  String    @map("category_id") @db.Uuid
  name        String
  description String    @default("")
  position    Int       @default(100)
  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  contents    Content[]
  createdBy   User?     @relation("SubcategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([categoryId, name])
  @@index([categoryId], map: "subcategories_category_id_idx")
  @@index([createdById], map: "subcategories_created_by_id_idx")
  @@map("subcategories")
}

model JournalistProfile {
  id            Boolean   @id @default(true)
  userId        String?   @unique @map("user_id") @db.Uuid
  imageUrl      String    @default("") @map("image_url")
  displayName   String    @default("") @map("display_name")
  jobTitle      String    @default("") @map("job_title")
  tagline       String    @default("")
  bio           String    @default("")
  bioShort      String    @default("") @map("bio_short")
  specialties   String[]  @default([])
  heroVideoUrl  String    @default("") @map("hero_video_url")
  heroPosterUrl String    @default("") @map("hero_poster_url")
  photoCaption  String    @default("") @map("photo_caption")
  editorialLine String    @default("") @map("editorial_line")
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("journalist_profile")
}

model SiteSettings {
  id                    Boolean  @id @default(true)
  footerTagline         String   @default("") @map("footer_tagline")
  contactIntro          String   @default("") @map("contact_intro")
  contactRole           String   @default("") @map("contact_role")
  newsletterEyebrow     String   @default("") @map("newsletter_eyebrow")
  newsletterTitle       String   @default("") @map("newsletter_title")
  homeAboutEyebrow      String   @default("") @map("home_about_eyebrow")
  homeAboutTitle        String   @default("") @map("home_about_title")
  collaborerEyebrow     String   @default("") @map("collaborer_eyebrow")
  collaborerHeroTitle   String   @default("") @map("collaborer_hero_title")
  collaborerHeroSubtitle String  @default("") @map("collaborer_hero_subtitle")
  collaborerCtaLabel    String   @default("") @map("collaborer_cta_label")
  collaborerCtaHref     String   @default("") @map("collaborer_cta_href")
  collaborerClosingTitle String  @default("") @map("collaborer_closing_title")
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}

model CredibilityItem {
  id        String          @id @default(uuid()) @db.Uuid
  kind      CredibilityKind
  name      String          @default("")
  title     String          @default("")
  subtitle  String          @default("")
  year      String          @default("")
  logoUrl   String          @default("") @map("logo_url")
  initials  String          @default("")
  linkUrl   String          @default("") @map("link_url")
  position  Int             @default(100)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([kind, position], map: "credibility_items_kind_position_idx")
  @@index([isActive], map: "credibility_items_is_active_idx")
  @@map("credibility_items")
}

model TimelineStep {
  id        String   @id @default(uuid()) @db.Uuid
  period    String
  title     String
  text      String   @default("")
  position  Int      @default(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([position], map: "timeline_steps_position_idx")
  @@map("timeline_steps")
}

model SocialLink {
  id        String   @id @default(uuid()) @db.Uuid
  platform  String
  label     String
  url       String
  position  Int      @default(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([position], map: "social_links_position_idx")
  @@index([isActive], map: "social_links_is_active_idx")
  @@map("social_links")
}

model CollaborationOffer {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  tag       String   @default("")
  position  Int      @default(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([position], map: "collaboration_offers_position_idx")
  @@map("collaboration_offers")
}

model CollaborationCase {
  id        String   @id @default(uuid()) @db.Uuid
  number    String   @default("")
  title     String
  format    String   @default("")
  note      String   @default("")
  position  Int      @default(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([position], map: "collaboration_cases_position_idx")
  @@map("collaboration_cases")
}

model Content {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  type        ContentType
  content     String      @default("")
  imageUrl    String      @default("") @map("image_url")
  tags        String[]    @default([])
  categoryId    String?      @map("category_id") @db.Uuid
  subcategoryId String?      @map("subcategory_id") @db.Uuid
  createdById   String?      @map("created_by_id") @db.Uuid
  isFeatured    Boolean            @default(false) @map("is_featured")
  status        PublicationStatus  @default(draft)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  category      Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory   Subcategory?       @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  createdBy     User?              @relation("ContentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)], map: "contents_created_at_idx")
  @@index([categoryId], map: "contents_category_id_idx")
  @@index([subcategoryId], map: "contents_subcategory_id_idx")
  @@index([createdById], map: "contents_created_by_id_idx")
  @@index([isFeatured], map: "contents_is_featured_idx")
  @@index([status], map: "contents_status_idx")
  @@map("contents")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String   @default("")
  date        DateTime @db.Timestamptz(6)
  location    String             @default("")
  status      PublicationStatus  @default(draft)
  isFeatured       Boolean            @default(false) @map("is_featured")
  reminderEnabled  Boolean            @default(false) @map("reminder_enabled")
  reminderSentAt   DateTime?          @map("reminder_sent_at") @db.Timestamptz(6)
  createdById String?            @map("created_by_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   User?              @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date(sort: Asc)], map: "events_date_idx")
  @@index([createdAt(sort: Desc)], map: "events_created_at_idx")
  @@index([createdById], map: "events_created_by_id_idx")
  @@index([status], map: "events_status_idx")
  @@index([isFeatured], map: "events_is_featured_idx")
  @@index([reminderEnabled, reminderSentAt, date], map: "events_reminder_due_idx")
  @@map("events")
}

model Subscriber {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  fullName      String?   @map("full_name")
  isActive      Boolean   @default(true) @map("is_active")
  subscribedAt  DateTime  @default(now()) @map("subscribed_at") @db.Timestamptz(6)
  unsubscribedAt DateTime? @map("unsubscribed_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive], map: "subscribers_is_active_idx")
  @@index([subscribedAt(sort: Desc)], map: "subscribers_subscribed_at_idx")
  @@map("subscribers")
}

model NewsletterCampaign {
  id              String                 @id @default(uuid()) @db.Uuid
  kind            NewsletterCampaignKind
  subject         String
  referenceId     String?                @map("reference_id") @db.Uuid
  totalRecipients Int                    @map("total_recipients")
  sentCount       Int                    @map("sent_count")
  failedCount     Int                    @map("failed_count")
  sentAt          DateTime               @default(now()) @map("sent_at") @db.Timestamptz(6)

  @@index([sentAt(sort: Desc)], map: "newsletter_campaigns_sent_at_idx")
  @@map("newsletter_campaigns")
}
