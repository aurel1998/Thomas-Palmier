# ============================================================
#  Production VPS IONOS — thomaspalmier.fr
#  Sur le VPS : npm run env:init   (génère JWT + CRON automatiquement)
#  Puis nano .env → remplace les 3 CHANGEME restants.
#  Puis : npm run deploy:vps
#  VPS : root@217.160.191.235 (Rocky 9) — voir deploy/VPS.md
#  Guide : IONOS_QUICKSTART.md
# ============================================================

NODE_ENV=production

# --- Base PostgreSQL (mot de passe DB à personnaliser) ---
DATABASE_URL="postgresql://sport:CHANGEME_MOT_DE_PASSE_DB@localhost:5432/sport_journal?schema=public"

# --- Sessions NextAuth (générer : openssl rand -base64 32) ---
JWT_SECRET="CHANGEME_JWT_SECRET"
NEXTAUTH_URL="https://thomaspalmier.fr"
NEXT_PUBLIC_APP_URL="https://thomaspalmier.fr"
NEXT_PUBLIC_SITE_NAME="Thomas Palmier"
NEXT_PUBLIC_SITE_DESCRIPTION="Thomas Palmier, journaliste sportif : analyses, reportages terrain, vidéos et formats courts."
# Optionnel — Search Console (balise meta google-site-verification)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# --- Admin /monsite (seul compte autorisé) ---
ADMIN_EMAIL="contact@thomaspalmier.fr"
ADMIN_PASSWORD="CHANGEME_MOT_DE_PASSE_ADMIN"

# --- Contact public (affiché sur /contact, mailto partenariats) ---
CONTACT_EMAIL="contact@thomaspalmier.fr"
NEXT_PUBLIC_CONTACT_EMAIL="contact@thomaspalmier.fr"
NEXT_PUBLIC_ADMIN_EMAIL_HINT="contact@thomaspalmier.fr"

# --- Newsletter SMTP IONOS (envoi depuis contact@thomaspalmier.fr) ---
EMAIL_USER="contact@thomaspalmier.fr"
EMAIL_PASS="CHANGEME_MOT_DE_PASSE_BOITE_MAIL"
SMTP_HOST="smtp.ionos.fr"
SMTP_PORT="587"
SMTP_SECURE="false"
MAIL_FROM="Thomas Palmier <contact@thomaspalmier.fr>"

# --- Cron VPS (rappels agenda 24 h avant) — générer : openssl rand -base64 32
CRON_SECRET="CHANGEME_CRON_SECRET"
